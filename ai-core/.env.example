# ── AI Core Environment ──────────────────────────
# Copy this file to .env and fill in the values

# Server
HOST=0.0.0.0
PORT=8000

# Gateway URL (for progress reporting)
GATEWAY_URL=http://localhost:3000

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=autonomousqa

# OpenAI (optional — for AI-powered test generation)
OPENAI_API_KEY=your_openai_api_key_here

# Gemini Vision (optional — for AI visual bug detection)
# Get a FREE key at: https://aistudio.google.com (no credit card needed)
GEMINI_API_KEY=

# Playwright
HEADLESS=true
BROWSER=chromium
